{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tinacms dev -c \"next dev --port 3000\"",
    "dev:next": "next dev --port 3000",
    "build": "(tinacms build && rm -f public/admin/.gitignore) || echo 'Tina build skipped (missing token), using committed generated files' && next build",
    "start": "next start",
    "clean": "rm -rf .next out",
    "lint": "tsc --noEmit",
    "deploy": "npm run build && touch out/.nojekyll && cp public/CNAME out/CNAME 2>/dev/null; echo 'Build ready in out/ — push to gh-pages branch to deploy'"
  },
  "homepage": "https://vish.studio",
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next": "^15.5.12",
    "posthog-js": "^1.358.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "tinacms": "^3.6.0"
  },
  "devDependencies": {
    "@tinacms/cli": "^2.1.8",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
